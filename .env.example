# Copy to .env — never commit .env
# Account locator, e.g. xy12345.us-east-1 or myorg-myaccount

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=

# SSO (recommended): opens browser once per session
SNOWFLAKE_AUTHENTICATOR=EXTERNALBROWSER
# Leave password empty for SSO
SNOWFLAKE_PASSWORD=

# Optional context (sets default namespace for unqualified names)
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# Optional: default SQL for Streamlit text area (use \\n for newlines in one line, or skip)
# PILOT_DEFAULT_SQL=
